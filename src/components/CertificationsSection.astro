---
const certifications = [
	{
		title: "Analista Programador",
		institution: "Universidad ORT Uruguay",
		year: "2024",
		credentialId: "AP-2024-ORT",
		image: "/ort_logo.png",
		link: "/titulo.png",
		highlight: true,
		icon: "🎓",
		color: "from-red-500 to-red-600"
	},
	{
		title: "Desarrollo Mobile Android",
		institution: "Instituto BIOS",
		year: "2016",
		credentialId: "ANDROID-2016",
		image: "/certificates/android.jpg",
		link: "#",
		highlight: false,
		icon: "📱",
		color: "from-green-500 to-green-600"
	},
	{
		title: "Técnico en Hardware y Software",
		institution: "IAC Computación",
		year: "2003",
		credentialId: "THS-2003",
		image: "/certificates/hardware.jpg",
		link: "#",
		highlight: false,
		icon: "🔧",
		color: "from-slate-500 to-slate-600"
	}
];
---

<section id="certificaciones" class="py-24 bg-white dark:bg-slate-900 scroll-mt-24" data-aos="fade-up">
	<div class="max-w-6xl mx-auto px-6">
		<div class="text-center mb-16">
			<span class="inline-block px-4 py-2 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full text-sm font-medium mb-4">
				Certificaciones
			</span>
			<h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100 font-serif">
				Logros Académicos
			</h2>
		</div>

		<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
			{certifications.map((cert, index) => (
				<div
					class={`group bg-slate-50 dark:bg-slate-800 rounded-3xl overflow-hidden border transition-all duration-300 hover:shadow-xl hover:-translate-y-1 ${
						cert.highlight ? 'border-amber-200 dark:border-amber-800' : 'border-slate-100 dark:border-slate-700'
					}`}
					data-aos="fade-up"
					data-aos-delay={index * 100}
				>
					<div class="relative h-36 bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-900 overflow-hidden">
						<div class="absolute inset-0 flex items-center justify-center">
							<div class="text-center">
								<div class={`inline-flex w-16 h-16 rounded-2xl bg-gradient-to-br ${cert.color} items-center justify-center text-3xl shadow-lg mb-3 group-hover:scale-110 transition-transform duration-300`}>
									{cert.icon}
								</div>
							</div>
						</div>
						{cert.highlight && (
							<div class="absolute top-4 right-4 px-3 py-1.5 bg-amber-500 text-white text-xs font-bold rounded-full shadow-lg flex items-center gap-1.5">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
								</svg>
								Principal
							</div>
						)}
					</div>

					<div class="p-6">
						<h3 class="font-serif font-bold text-lg mb-3 text-slate-900 dark:text-slate-100 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">
							{cert.title}
						</h3>

						<div class="flex items-center gap-3 mb-4">
							<div class="w-10 h-10 rounded-xl bg-white dark:bg-slate-900 flex items-center justify-center shadow-sm">
								<span class="text-lg">🏛️</span>
							</div>
							<div>
								<p class="text-sm font-medium text-slate-900 dark:text-slate-100">{cert.institution}</p>
								<p class="text-xs text-slate-500 dark:text-slate-400">{cert.year}</p>
							</div>
						</div>

						<a
							href={cert.link}
							target="_blank"
							class="inline-flex items-center gap-2 text-sm text-amber-600 dark:text-amber-400 hover:text-amber-700 dark:hover:text-amber-300 font-medium transition-colors group/link"
						>
							<span>Ver certificado</span>
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 group-hover/link:translate-x-1 transition-transform">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
							</svg>
						</a>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
