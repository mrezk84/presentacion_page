---
import Icon from "./Icon.astro";

const certifications = [
	{
		title: "Agile Frameworks: Scrum & Kanban",
		institution: "Udemy",
		year: "2024",
		credentialId: "UC-12a8ec05",
		image: "/UC-12a8ec05-abc6-4bc2-a6dc-3234366d9585.pdf",
		link: "/UC-12a8ec05-abc6-4bc2-a6dc-3234366d9585.pdf",
		highlight: true,
		icon: "trophy",
		color: "from-gradient-uc",
		program: "Certificación Profesional"
	},
	{
		title: "Analista Programador",
		institution: "Universidad ORT Uruguay",
		year: "2024",
		credentialId: "AP-2024-ORT",
		image: "/ort_logo.png",
		link: "/titulo.png",
		highlight: true,
		icon: "academic",
		color: "from-gradient-ort",
		program: "Carrera Universitaria"
	},
	{
		title: "Desarrollo Mobile Android",
		institution: "Instituto BIOS",
		year: "2016",
		credentialId: "ANDROID-2016",
		image: "/certificates/android.jpg",
		link: "#",
		highlight: false,
		icon: "window",
		color: "from-gradient-android",
		program: "Especialización"
	},
	{
		title: "Técnico en Hardware y Software",
		institution: "IAC Computación",
		year: "2003",
		credentialId: "THS-2003",
		image: "/certificates/hardware.jpg",
		link: "#",
		highlight: false,
		icon: "cube",
		color: "from-gradient-hardware",
		program: "Certificación Técnica"
	}
];
---

<section id="certificaciones" class="py-24 bg-gradient-to-b from-white to-slate-50 dark:from-slate-900 dark:to-slate-800 scroll-mt-24 overflow-hidden" data-aos="fade-up">
	<!-- Background Elements -->
	<div class="absolute inset-0 overflow-hidden pointer-events-none">
		<div class="absolute -top-40 -right-40 w-80 h-80 bg-gradient-to-br from-amber-400/10 to-orange-500/10 rounded-full blur-3xl"></div>
		<div class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-tr from-blue-400/10 to-cyan-500/10 rounded-full blur-3xl"></div>
	</div>

	<div class="max-w-7xl mx-auto px-6 relative">
		<!-- Header Section -->
		<div class="text-center mb-20">
			<div class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 border border-amber-200 dark:border-amber-800 rounded-full text-sm font-medium text-amber-700 dark:text-amber-300 mb-6 shadow-sm">
				<span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></span>
				Certificaciones Profesionales
			</div>

			<h2 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-slate-900 dark:text-slate-100 font-serif mb-6 bg-clip-text text-transparent bg-gradient-to-r from-slate-900 via-slate-700 to-slate-900 dark:from-slate-100 dark:via-slate-300 dark:to-slate-100">
				Logros Académicos
			</h2>

			<p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
				Certificaciones que avalan mi experiencia y conocimiento en desarrollo de software y tecnologías modernas
			</p>
		</div>

		<!-- Certifications Grid -->
		<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
			{certifications.map((cert, index) => (
				<div
					class={`group relative bg-white dark:bg-slate-800/50 backdrop-blur-xl rounded-3xl overflow-hidden border transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 ${
						cert.highlight
							? 'border-gradient-orth shadow-lg'
							: 'border-slate-200/50 dark:border-slate-700/50'
					}`}
					data-aos="fade-up"
					data-aos-delay={index * 150}
					data-aos-duration="800"
				>
					<!-- Gradient Border Effect -->
					{cert.highlight && (
						<div class="absolute inset-0 bg-gradient-to-br from-amber-400/20 via-orange-500/10 to-red-500/20 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					)}

					<!-- Header with Icon -->
					<div class="relative h-44 bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-800 dark:to-slate-900 overflow-hidden">
						<!-- Animated Background Pattern -->
						<div class="absolute inset-0 opacity-5">
							<div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, currentColor 1px, transparent 0); background-size: 24px 24px;"></div>
						</div>

						<div class="absolute inset-0 flex items-center justify-center">
							<div class="text-center transform transition-all duration-500 group-hover:scale-110">
								<div class="inline-flex w-20 h-20 rounded-3xl bg-amber-500/10 text-amber-600 dark:text-amber-400 ring-1 ring-amber-500/20 items-center justify-center shadow-sm mb-4">
									<Icon name={cert.icon} class="w-9 h-9" />
								</div>

								{cert.highlight && (
									<div class="flex items-center justify-center gap-2 mt-4">
										<div class="px-3 py-1.5 bg-gradient-to-r from-amber-500 to-orange-500 text-white text-xs font-bold rounded-full shadow-lg flex items-center gap-1.5">
											<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
												<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
											</svg>
											Destacado
										</div>
									</div>
								)}
							</div>
						</div>

						<!-- Year Badge -->
						<div class="absolute top-4 left-4 px-3 py-1 bg-white/90 dark:bg-slate-800/90 backdrop-blur-sm text-slate-700 dark:text-slate-300 text-xs font-bold rounded-full shadow-md border border-slate-200 dark:border-slate-700">
							{cert.year}
						</div>
					</div>

					<!-- Content -->
					<div class="relative p-6">
						<h3 class="font-serif font-bold text-xl mb-3 text-slate-900 dark:text-slate-100 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-amber-600 group-hover:to-orange-600 dark:group-hover:from-amber-400 dark:group-hover:to-orange-400 transition-all duration-300 leading-tight">
							{cert.title}
						</h3>

						<!-- Institution Info -->
						<div class="flex items-center gap-3 mb-4 p-3 bg-slate-50 dark:bg-slate-900/50 rounded-2xl border border-slate-100 dark:border-slate-700">
							<div class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400">
								<Icon name="building" class="w-6 h-6" />
							</div>
							<div class="flex-1 min-w-0">
								<p class="text-sm font-semibold text-slate-900 dark:text-slate-100 truncate">{cert.institution}</p>
								<p class="text-xs text-slate-500 dark:text-slate-400 truncate">{cert.program}</p>
							</div>
						</div>

						<!-- Credential ID -->
						<div class="mb-4 px-3 py-2 bg-slate-50 dark:bg-slate-900/30 rounded-xl border border-slate-200 dark:border-slate-700">
							<p class="text-xs text-slate-500 dark:text-slate-400 mb-1">ID de Credencial</p>
							<p class="text-xs font-mono text-slate-700 dark:text-slate-300 truncate">{cert.credentialId}</p>
						</div>

						<!-- View Certificate Button -->
						<a
							href={cert.link}
							target="_blank"
							rel="noopener noreferrer"
							class="w-full inline-flex items-center justify-center gap-2 px-4 py-3 bg-gradient-to-r from-slate-100 to-slate-200 dark:from-slate-700 dark:to-slate-800 hover:from-amber-100 hover:to-orange-100 dark:hover:from-amber-900/30 dark:hover:to-orange-900/30 text-slate-700 dark:text-slate-300 hover:text-amber-700 dark:hover:text-amber-400 font-medium rounded-xl transition-all duration-300 group/link shadow-sm hover:shadow-md border border-slate-200 dark:border-slate-700 hover:border-amber-300 dark:hover:border-amber-700"
						>
							<span class="text-sm">Ver Certificado</span>
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 group-hover/link:translate-x-1 group-hover/link:-translate-y-0.5 transition-all">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
							</svg>
						</a>
					</div>

					<!-- Hover Glow Effect -->
					{cert.highlight && (
						<div class="absolute -inset-1 bg-gradient-to-r from-amber-500 to-orange-500 rounded-3xl opacity-0 group-hover:opacity-20 blur-xl transition-opacity duration-500 -z-10"></div>
					)}
				</div>
			))}
		</div>

		<!-- Bottom CTA Section -->
		<div class="mt-16 text-center">
			<div class="inline-flex items-center gap-3 px-6 py-3 bg-gradient-to-r from-slate-50 to-slate-100 dark:from-slate-800/50 dark:to-slate-900/50 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm">
				<div class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white font-bold">
					{certifications.length}
				</div>
				<div class="text-left">
					<p class="text-sm font-medium text-slate-900 dark:text-slate-100">Certificaciones Obtenidas</p>
					<p class="text-xs text-slate-500 dark:text-slate-400">Formación continua en desarrollo</p>
				</div>
			</div>
		</div>
	</div>
</section>
