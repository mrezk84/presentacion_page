---
const testimonials = [
	{
		name: "Gestión de Proyectos",
		role: "SONDA Uruguay",
		content: "Marcos ha demostrado un excelente rendimiento técnico y capacidad de liderazgo en proyectos críticos para el Ministerio del Interior. Su atención al detalle y compromiso con la calidad son notables.",
		avatar: "👨‍💼",
		rating: 5,
		color: "from-blue-400 to-blue-600"
	},
	{
		name: "Equipo de Desarrollo",
		role: "Ministerio del Interior",
		content: "Su capacidad para resolver problemas complejos y optimizar consultas en SQL Server mejoró significativamente el rendimiento de nuestras aplicaciones. Un profesional muy comprometido.",
		avatar: "👨‍💻",
		rating: 5,
		color: "from-amber-400 to-amber-600"
	},
	{
		name: "Calidad y Excelencia",
		role: "SEMM",
		content: "La implementación del módulo de eventos y reportes superó nuestras expectativas. Marcos combina habilidades técnicas sólidas con una excelente comunicación.",
		avatar: "👩‍💼",
		rating: 5,
		color: "from-emerald-400 to-emerald-600"
	}
];
---

<section id="testimonios" class="py-24 bg-slate-50 dark:bg-slate-950 scroll-mt-24" data-aos="fade-up">
	<div class="max-w-6xl mx-auto px-6">
		<div class="text-center mb-16">
			<span class="inline-block px-4 py-2 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full text-sm font-medium mb-4">
				Recomendaciones
			</span>
			<h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100 font-serif">
				Lo que dicen de mí
			</h2>
		</div>

		<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
			{testimonials.map((testimonial, index) => (
				<div
					class="group relative bg-white dark:bg-slate-900 rounded-3xl p-8 shadow-lg border border-slate-100 dark:border-slate-800 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 overflow-hidden"
					data-aos="fade-up"
					data-aos-delay={index * 100}
				>
					<!-- Decorative gradient blob -->
					<div class={`absolute -top-12 -right-12 w-32 h-32 bg-gradient-to-br ${testimonial.color} rounded-full blur-3xl opacity-10 group-hover:opacity-20 transition-opacity`}></div>

					<div class="relative">
						<!-- Rating -->
						<div class="flex items-center gap-1 mb-6">
							{Array.from({ length: testimonial.rating }).map(() => (
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-amber-500">
									<path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
								</svg>
							))}
						</div>

						<!-- Quote -->
						<p class="text-slate-600 dark:text-slate-300 mb-8 leading-relaxed text-sm relative">
							<span class="absolute -top-2 -left-2 text-6xl text-amber-200 dark:text-amber-900 font-serif opacity-50">"</span>
							<span class="relative">{testimonial.content}</span>
						</p>

						<!-- Author -->
						<div class="flex items-center gap-4">
							<div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-amber-100 to-yellow-100 dark:from-amber-900/30 dark:to-yellow-900/30 flex items-center justify-center text-3xl shadow-inner">
								{testimonial.avatar}
							</div>
							<div>
								<h4 class="font-semibold text-slate-900 dark:text-slate-100">{testimonial.name}</h4>
								<p class="text-sm text-amber-600 dark:text-amber-400">{testimonial.role}</p>
							</div>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
