---
const languages = [
	{
		name: "Español",
		level: "Nativo",
		levelPercent: 100,
		flag: "🇺🇾",
		color: "from-blue-500 to-blue-600"
	},
	{
		name: "Inglés",
		level: "Intermedio - Avanzado",
		levelPercent: 75,
		flag: "🇬🇧",
		color: "from-red-500 to-red-600"
	},
	{
		name: "Portugués",
		level: "Intermedio",
		levelPercent: 50,
		flag: "🇧🇷",
		color: "from-green-500 to-green-600"
	}
];
---

<section id="idiomas" class="py-24 bg-slate-50 dark:bg-slate-950 scroll-mt-24" data-aos="fade-up">
	<div class="max-w-6xl mx-auto px-6">
		<div class="text-center mb-16">
			<span class="inline-block px-4 py-2 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full text-sm font-medium mb-4">
				Comunicación
			</span>
			<h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100 font-serif">
				Idiomas que domino
			</h2>
		</div>

		<div class="grid gap-6 md:grid-cols-3">
			{languages.map((lang, index) => (
				<div
					class="bg-white dark:bg-slate-900 rounded-3xl shadow-lg border border-slate-100 dark:border-slate-800 p-8 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 group"
					data-aos="fade-up"
					data-aos-delay={index * 100}
				>
					<div class="flex items-center gap-4 mb-6">
						<div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-700 flex items-center justify-center text-4xl group-hover:scale-110 transition-transform duration-300 shadow-inner">
							{lang.flag}
						</div>
						<div>
							<h3 class="font-serif font-bold text-xl text-slate-900 dark:text-slate-100">
								{lang.name}
							</h3>
							<p class="text-sm text-amber-600 dark:text-amber-400 font-medium mt-0.5">{lang.level}</p>
						</div>
					</div>

					<div class="relative h-2.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
						<div
							class={`h-full bg-gradient-to-r ${lang.color} rounded-full transition-all duration-1000 ease-out`}
							style="width: 0%"
							data-width={lang.levelPercent}
						></div>
					</div>

					<div class="mt-3 flex justify-between items-center">
						<span class="text-xs text-slate-500 dark:text-slate-400">Nivel de dominio</span>
						<span class="text-sm font-bold text-slate-700 dark:text-slate-300">{lang.levelPercent}%</span>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<script>
	// Animate language bars on scroll
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const bar = entry.target.querySelector('[data-width]');
				if (bar) {
					const width = bar.getAttribute('data-width');
					setTimeout(() => {
						(bar as HTMLElement).style.width = width + '%';
					}, 300);
				}
			}
		});
	}, { threshold: 0.5 });

	document.querySelectorAll('#idiomas .group').forEach(el => {
		observer.observe(el);
	});
</script>
