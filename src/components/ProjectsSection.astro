---
// Fetch real GitHub repositories
const githubRepos = [
	{
		name: "Control_Gastos",
		full_name: "mrezk84/Control_Gastos",
		description: "Programa para el control de gastos personales realizado con backend Python y FrontEnd React",
		language: "Python",
		html_url: "https://github.com/mrezk84/Control_Gastos",
		forks_count: 0,
		stargazers_count: 0,
		created_at: "2025-05-18",
		topics: ["python", "react", "backend", "frontend"]
	},
	{
		name: "ProyectoORT",
		full_name: "mrezk84/ProyectoORT",
		description: "Proyecto académico desarrollado durante la carrera en ORT Uruguay",
		language: "HTML",
		html_url: "https://github.com/mrezk84/ProyectoORT",
		forks_count: 0,
		stargazers_count: 0,
		created_at: "2023-06-22",
		topics: ["html", "javascript", "academic"]
	}
];

// Get base path
const isVercel = import.meta.env.VERCEL === '1';
const basePath = isVercel ? '' : '/presentacion_page';

// Language colors
const languageColors: Record<string, string> = {
	"Python": "bg-blue-500",
	"JavaScript": "bg-yellow-500",
	"HTML": "bg-orange-500",
	"Astro": "bg-purple-500",
	"CSS": "bg-blue-400",
	"TypeScript": "bg-blue-600",
};

const getLanguageColor = (lang: string) => languageColors[lang] || "bg-slate-500";

const formatDate = (dateStr: string) => {
	const date = new Date(dateStr);
	return date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long' });
};

// Combine with featured projects
const featuredProjects = [
	{
		title: "Sistema de Denuncias - Ministerio del Interior",
		description: "Aplicación web full stack para gestión de denuncias ciudadanas con React, C# .NET y SQL Server. Incluye mapa interactivo con ArcGIS, autenticación LDAP y exportación de reportes en PDF.",
		technologies: ["React", "C# .NET", "SQL Server", "ArcGIS", "LDAP"],
		link: "#",
		github: "#",
		highlight: true,
		isWorkProject: true,
		client: "Ministerio del Interior",
		year: "2024",
		icon: "🏛️"
	},
	{
		title: "Sistema 911 - Centro de Emergencias",
		description: "Sistema crítico de gestión de llamadas de emergencia con grabación de audio, geolocalización y distribución en tiempo real. Frontend XAML, backend C# con WCF, mapa ArcGIS e integración Asterisk para telefonía IP.",
		technologies: ["C#", "WCF", "XAML", "ArcGIS", "Asterisk"],
		link: "#",
		github: "#",
		highlight: true,
		isWorkProject: true,
		client: "Centro de Emergencias 911",
		year: "2023",
		icon: "🚨"
	},
	{
		title: "SEMM - Gestión de Eventos",
		description: "Plataforma de gestión de eventos y monitoreo para servicios de emergencia médica. Incluye dashboard en tiempo real y módulo de estadísticas.",
		technologies: ["React", "C#", "SQL Server", "Chart.js"],
		link: "#",
		github: "#",
		highlight: true,
		isWorkProject: true,
		client: "SEMM",
		year: "2023",
		icon: "🏥"
	}
];
---

<section id="proyectos" class="py-24 bg-white dark:bg-slate-900 scroll-mt-24" data-aos="fade-up">
	<div class="max-w-6xl mx-auto px-6">
		<div class="text-center mb-16">
			<span class="inline-block px-4 py-2 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full text-sm font-medium mb-4">
				Portafolio
			</span>
			<h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100 font-serif">
				Proyectos Destacados
			</h2>
			<p class="text-lg text-slate-600 dark:text-slate-400 mt-4 max-w-2xl mx-auto">
				Una selección de proyectos profesionales en los que he trabajado y repositorios personales disponibles en GitHub.
			</p>
		</div>

		<!-- Featured Work Projects -->
		<div class="mb-16">
			<h3 class="text-xl font-semibold mb-8 text-slate-700 dark:text-slate-300 flex items-center gap-3">
				<span class="w-10 h-10 rounded-xl bg-gradient-to-br from-amber-400 to-yellow-500 flex items-center justify-center text-white shadow-lg">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008z" />
					</svg>
				</span>
				Proyectos Profesionales
			</h3>
			<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
				{featuredProjects.map((project, index) => (
					<div
						class="group bg-slate-50 dark:bg-slate-800 rounded-3xl overflow-hidden hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-slate-100 dark:border-slate-700"
						data-aos="fade-up"
						data-aos-delay={index * 100}
					>
						<div class="relative h-44 bg-gradient-to-br from-amber-100 via-amber-50 to-yellow-100 dark:from-amber-900/30 dark:via-slate-800 dark:to-slate-900 overflow-hidden">
							<div class="absolute inset-0 flex items-center justify-center">
								<div class="text-center">
									<div class="text-5xl mb-2 drop-shadow-lg">{project.icon}</div>
									<p class="text-sm text-slate-600 dark:text-slate-400 font-medium px-4">{project.client}</p>
								</div>
							</div>
							<div class="absolute top-4 right-4 px-3 py-1.5 bg-white dark:bg-slate-900 text-amber-600 dark:text-amber-400 text-xs font-bold rounded-full shadow-lg flex items-center gap-1.5">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
								</svg>
								Destacado
							</div>
							<div class="absolute bottom-4 left-4 px-3 py-1 bg-slate-900/80 backdrop-blur-sm text-white text-xs rounded-lg">
								{project.year}
							</div>
						</div>

						<div class="p-6">
							<h3 class="font-serif font-bold text-xl mb-3 text-slate-900 dark:text-slate-100 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors line-clamp-2">
								{project.title}
							</h3>

							<p class="text-slate-600 dark:text-slate-400 text-sm mb-5 leading-relaxed line-clamp-3">
								{project.description}
							</p>

							<div class="flex flex-wrap gap-2">
								{project.technologies.slice(0, 4).map((tech) => (
									<span class="px-3 py-1 bg-white dark:bg-slate-900 rounded-lg text-xs text-slate-700 dark:text-slate-300 font-medium border border-slate-200 dark:border-slate-600 shadow-sm">
										{tech}
									</span>
								))}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>

		<!-- GitHub Repositories -->
		<div>
			<h3 class="text-xl font-semibold mb-8 text-slate-700 dark:text-slate-300 flex items-center gap-3">
				<span class="w-10 h-10 rounded-xl bg-slate-800 dark:bg-slate-700 flex items-center justify-center text-white shadow-lg">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" class="text-white">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
					</svg>
				</span>
				Repositorios en GitHub
				<a href="https://github.com/mrezk84?tab=repositories" target="_blank" rel="noopener noreferrer" class="text-amber-600 dark:text-amber-400 text-sm font-normal hover:underline ml-auto flex items-center gap-1 group">
					Ver todos
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform">
						<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
					</svg>
				</a>
			</h3>
			<div class="grid gap-6 md:grid-cols-2">
				{githubRepos.map((repo, index) => (
					<a
						href={repo.html_url}
						target="_blank"
						rel="noopener noreferrer"
						class="group bg-slate-50 dark:bg-slate-800 rounded-2xl p-6 border border-slate-100 dark:border-slate-700 hover:border-amber-500/30 hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
						data-aos="fade-up"
						data-aos-delay={index * 100}
					>
						<div class="flex items-start justify-between mb-4">
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 rounded-xl bg-white dark:bg-slate-900 shadow-md flex items-center justify-center group-hover:scale-110 transition-transform">
									<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16" class="text-slate-600 dark:text-slate-400">
										<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
									</svg>
								</div>
								<div>
									<h4 class="font-semibold text-slate-900 dark:text-slate-100 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">
										{repo.name}
									</h4>
									<p class="text-xs text-slate-500 dark:text-slate-400 mt-1">
										Creado: {formatDate(repo.created_at)}
									</p>
								</div>
							</div>
							<div class={`w-3 h-3 rounded-full ${getLanguageColor(repo.language)}`} title={repo.language}></div>
						</div>

						<p class="text-slate-600 dark:text-slate-400 text-sm mb-5 line-clamp-2 leading-relaxed">
							{repo.description}
						</p>

						<div class="flex items-center gap-5 text-xs text-slate-500 dark:text-slate-400">
							<span class="flex items-center gap-1.5">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
									<path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
								</svg>
								{repo.stargazers_count}
							</span>
							<span class="flex items-center gap-1.5">
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
									<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
								</svg>
								{repo.forks_count}
							</span>
							<span class="ml-auto px-3 py-1 bg-white dark:bg-slate-900 rounded-lg font-mono border border-slate-200 dark:border-slate-600">
								{repo.language}
							</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.line-clamp-3 {
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
