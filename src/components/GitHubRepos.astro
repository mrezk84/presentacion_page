---
// Fetch real GitHub repositories from API
const githubUsername = "mrezk84";
const githubApiUrl = `https://api.github.com/users/${githubUsername}/repos?sort=updated&per_page=6`;

let githubRepos: any[] = [];

try {
	const response = await fetch(githubApiUrl);
	if (response.ok) {
		githubRepos = await response.json();
	}
} catch (error) {
	console.error("Error fetching GitHub repos:", error);
}

// Language colors mapping
const getLanguageColor = (lang: string) => {
	const colors: Record<string, string> = {
		"TypeScript": "bg-blue-600",
		"JavaScript": "bg-yellow-500",
		"Python": "bg-blue-500",
		"HTML": "bg-orange-500",
		"CSS": "bg-blue-400",
		"Astro": "bg-purple-500",
		"C#": "bg-purple-600",
		"Java": "bg-red-500",
		"Go": "bg-cyan-500",
		"Shell": "bg-green-500",
		"Ruby": "bg-red-600",
		"PHP": "bg-indigo-500",
		"Swift": "bg-orange-500",
		"Kotlin": "bg-purple-500",
		"Rust": "bg-orange-600",
		"Vue": "bg-green-500",
		"React": "bg-cyan-500",
		"Scala": "bg-red-500",
		"Dart": "bg-blue-400",
	};
	return colors[lang] || "bg-slate-500";
};

const formatDate = (dateStr: string) => {
	const date = new Date(dateStr);
	const now = new Date();
	const diffTime = Math.abs(now.getTime() - date.getTime());
	const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

	if (diffDays === 1) return "Ayer";
	if (diffDays < 7) return `Hace ${diffDays} días`;
	if (diffDays < 30) return `Hace ${Math.floor(diffDays / 7)} semanas`;
	if (diffDays < 365) return `Hace ${Math.floor(diffDays / 30)} meses`;
	return `Hace ${Math.floor(diffDays / 365)} años`;
};
---

<section id="github" class="py-24 bg-slate-50 dark:bg-slate-950 scroll-mt-24" data-aos="fade-up">
	<div class="max-w-6xl mx-auto px-6">
		<div class="text-center mb-16">
			<span class="inline-block px-4 py-2 bg-slate-800 dark:bg-slate-700 text-white rounded-full text-sm font-medium mb-4">
				Open Source
			</span>
			<h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100 font-serif">
				Repositorios Recientes
			</h2>
			<p class="text-lg text-slate-600 dark:text-slate-400 mt-4 max-w-2xl mx-auto">
				Mis últimos proyectos en GitHub. Código abierto, contribuciones y experimentos.
			</p>
		</div>

		{githubRepos.length > 0 ? (
			<>
				<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
					{githubRepos.map((repo, index) => (
						<a
							href={repo.html_url}
							target="_blank"
							rel="noopener noreferrer"
							class="group bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 hover:border-slate-400 dark:hover:border-slate-500 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col h-full"
							data-aos="fade-up"
							data-aos-delay={index * 100}
						>
							<div class="flex items-start justify-between mb-4">
								<div class="flex items-center gap-3">
									<div class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center group-hover:scale-110 transition-transform">
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16" class="text-slate-600 dark:text-slate-400">
											<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
										</svg>
									</div>
									<div class="flex-1 min-w-0">
										<h3 class="font-semibold text-slate-900 dark:text-slate-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors truncate">
											{repo.name}
										</h3>
										<p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
											Actualizado: {formatDate(repo.updated_at)}
										</p>
									</div>
								</div>
							</div>

							<p class="text-slate-600 dark:text-slate-400 text-sm mb-5 line-clamp-2 leading-relaxed flex-1">
								{repo.description || "Sin descripción"}
							</p>

							<div class="flex items-center justify-between pt-4 border-t border-slate-100 dark:border-slate-700">
								<div class="flex items-center gap-4">
									{repo.language && (
										<div class="flex items-center gap-1.5">
											<span class={`w-2.5 h-2.5 rounded-full ${getLanguageColor(repo.language)}`}></span>
											<span class="text-xs text-slate-600 dark:text-slate-400">{repo.language}</span>
										</div>
									)}
								</div>
								<div class="flex items-center gap-3 text-xs text-slate-500 dark:text-slate-400">
									{repo.stargazers_count > 0 && (
										<span class="flex items-center gap-1">
											<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
												<path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.563 0 0 1-.84.61l-4.725-2.885a.562.563 0 0 0-.586 0L6.982 20.54a.562.563 0 0 1-.84-.61l1.285-5.386a.562.563 0 0 0-.182-.557l-4.204-3.602a.562.563 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
											</svg>
											{repo.stargazers_count}
										</span>
									)}
									{repo.forks_count > 0 && (
										<span class="flex items-center gap-1">
											<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
												<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
											</svg>
											{repo.forks_count}
										</span>
									)}
								</div>
							</div>
						</a>
					))}
				</div>

				<div class="text-center mt-12">
					<a
						href={`https://github.com/${githubUsername}?tab=repositories`}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-3 px-8 py-4 bg-slate-900 dark:bg-slate-800 text-white rounded-2xl font-semibold hover:bg-slate-800 dark:hover:bg-slate-700 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5 group"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16" class="text-white">
							<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
						</svg>
						<span>Ver todos mis repositorios</span>
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 group-hover:translate-x-1 transition-transform">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
						</svg>
					</a>
				</div>
			</>
		) : (
			<div class="text-center py-12">
				<div class="inline-flex items-center justify-center w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-full mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-slate-400">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 0 0-1.883 2.542l.857 6a2.25 2.25 0 0 0 2.227 1.932H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-1.883-2.542m-16.5 0V6A2.25 2.25 0 0 1 6 3.75h3.879a1.5 1.5 0 0 1 1.06.44l2.122 2.12a1.5 1.5 0 0 0 1.06.44H18A2.25 2.25 0 0 1 20.25 9v.776"/>
					</svg>
				</div>
				<h3 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-2">Cargando repositorios...</h3>
				<p class="text-slate-600 dark:text-slate-400">Visita mi <a href={`https://github.com/${githubUsername}`} target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline">GitHub</a> para ver todos mis proyectos.</p>
			</div>
		)}
	</div>
</section>

<style>
	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
