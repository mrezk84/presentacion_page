---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SkipLink from "../components/SkipLink.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import AOSInit from "../components/AOSInit";
import ProjectsSection from "../components/ProjectsSection.astro";
import GitHubRepos from "../components/GitHubRepos.astro";
import TestimonialsSection from "../components/TestimonialsSection.astro";
import CertificationsSection from "../components/CertificationsSection.astro";
import LanguagesSection from "../components/LanguagesSection.astro";
import "../styles/global.css";

const isVercel = process.env.VERCEL === '1';
const basePath = isVercel ? '' : '/presentacion_page';

const name = "Marcos Rezk";
const role = "Full Stack Developer";

const stats = [
  { value: "3+", label: "Años de experiencia" },
  { value: "10+", label: "Proyectos críticos" },
  { value: "15+", label: "Tecnologías dominadas" },
  { value: "100%", label: "Compromiso de calidad" }
];

const services = [
  {
    icon: "⚛️",
    title: "Desarrollo Frontend",
    description: "Aplicaciones web modernas con React, JavaScript y CSS. Interfaces responsivas y用户体验 optimizado.",
    technologies: ["React", "JavaScript", "HTML/CSS", "XAML"]
  },
  {
    icon: "🔷",
    title: "Desarrollo Backend",
    description: "APIs robustas y escalables con C# .NET, Node.js y Java. Integración con bases de datos SQL y NoSQL.",
    technologies: ["C# .NET", "Node.js", "Java", "Spring Boot"]
  },
  {
    icon: "🗄️",
    title: "Bases de Datos",
    description: "Diseño y optimización de esquemas. SQL Server, PostgreSQL, MongoDB. Mejoras de hasta 40% en rendimiento.",
    technologies: ["SQL Server", "PostgreSQL", "MongoDB", "MySQL"]
  },
  {
    icon: "🔗",
    title: "Integraciones",
    description: "Integración de servicios web, APIs REST/SOAP, LDAP, ArcGIS y sistemas de telefonía como Asterisk.",
    technologies: ["REST APIs", "WCF", "ArcGIS", "Asterisk"]
  }
];

const achievements = [
  { icon: "🏛️", text: "Sistemas críticos para el Ministerio del Interior" },
  { icon: "🚨", text: "Centro de Emergencias 911 - Gestión de llamadas" },
  { icon: "🏥", text: "SEMM - Plataforma de eventos médicos" },
  { icon: "🎓", text: "Egresado Analista Programador - ORT Uruguay" }
];
---

<Layout
  title="Marcos Rezk | Full Stack Developer - Disponible para trabajar"
  description="Full Stack Developer con experiencia en React, C# .NET, SQL Server, Java, Spring Boot y PostgreSQL. Desarrollador de sistemas críticos para el Ministerio del Interior y SEMM. Disponible para nuevas oportunidades."
>
  <SkipLink />
  <AOSInit client:load />

  <Header />
  <ScrollToTop />

  <main id="main-content" class="min-h-screen" role="main">
    <!-- Hero Section - Modern 2025 Design -->
    <section class="relative min-h-screen flex items-center overflow-hidden noise-bg">
      <!-- Modern Animated Background -->
      <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-amber-50/20 to-slate-100 dark:from-slate-950 dark:via-slate-900/50 dark:to-slate-950">
        <!-- Animated gradient orbs -->
        <div class="absolute inset-0 overflow-hidden">
          <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-gradient-to-br from-amber-400/20 via-yellow-300/10 to-transparent rounded-full blur-3xl animate-blob"></div>
          <div class="absolute -bottom-40 -left-40 w-[500px] h-[500px] bg-gradient-to-tr from-blue-400/15 via-cyan-300/10 to-transparent rounded-full blur-3xl animate-blob" style="animation-delay: 2s;"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-gradient-to-br from-amber-500/10 to-transparent rounded-full blur-3xl animate-pulse"></div>
        </div>
        <!-- Grid pattern overlay -->
        <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(rgba(0,0,0,1) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,1) 1px, transparent 1px); background-size: 60px 60px;"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 lg:py-0">
        <div class="grid lg:grid-cols-2 gap-12 items-center min-h-[80vh]">
          <!-- Text Content -->
          <div class="text-center lg:text-left order-2 lg:order-1 scroll-fade-in" data-aos="fade-right" data-aos-duration="1000">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 px-4 py-2 mb-6 bg-white/50 dark:bg-slate-800/50 rounded-full border border-amber-200/50 dark:border-amber-800/30 backdrop-blur-sm">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
              </span>
              <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Disponible para proyectos</span>
            </div>

            <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight mb-4">
              <span class="block text-slate-900 dark:text-slate-100">Hola, soy</span>
              <span class="block mt-2">
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-500 via-yellow-500 to-amber-600 dark:from-amber-400 dark:via-yellow-400 dark:to-amber-500 animate-gradient">
                  {name}
                </span>
              </span>
            </h1>

            <p class="text-2xl sm:text-3xl text-slate-700 dark:text-slate-300 mb-4">
              {role}
            </p>

            <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-6 max-w-xl mx-auto lg:mx-0">
              Especialista en desarrollo de aplicaciones web escalables con <strong class="text-slate-900 dark:text-slate-100">React</strong>, <strong class="text-slate-900 dark:text-slate-100">C# .NET</strong> y <strong class="text-slate-900 dark:text-slate-100">SQL Server</strong>. Egresado de <strong class="text-red-600 dark:text-red-400">ORT Uruguay</strong>.
            </p>

            <!-- Trust Badges -->
            <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4 mb-8">
              <div class="flex items-center gap-2 px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg">
                <span class="text-xl">🏛️</span>
                <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Ministerio del Interior</span>
              </div>
              <div class="flex items-center gap-2 px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg">
                <span class="text-xl">🚨</span>
                <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Sistema 911</span>
              </div>
              <div class="flex items-center gap-2 px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg">
                <span class="text-xl">🎓</span>
                <span class="text-sm font-medium text-slate-700 dark:text-slate-300">ORT Uruguay</span>
              </div>
            </div>

            <!-- CTAs - Primary Focus -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
              <a
                href="#contacto"
                class="group relative inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r from-amber-500 to-yellow-500 text-slate-900 rounded-2xl font-bold shadow-lg shadow-amber-500/30 hover:shadow-xl hover:shadow-amber-500/40 hover:-translate-y-1 transition-all duration-300 text-lg"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                <span>Contáctame</span>
              </a>
              <a
                href={`${basePath}/CV_Marcos_Rezk_ES.pdf`}
                download
                class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 rounded-2xl font-semibold border-2 border-slate-200 dark:border-slate-700 hover:border-amber-500 dark:hover:border-amber-500 hover:text-amber-600 dark:hover:text-amber-400 transition-all duration-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M12 12.75l-3-3m0 0 3-3m-3 3h7.5" />
                </svg>
                <span>Descargar CV</span>
              </a>
            </div>

            <!-- Social Proof -->
            <div class="flex items-center justify-center lg:justify-start gap-6 mt-8">
              <a href="https://www.linkedin.com/in/marcos-rezk" target="_blank" class="text-slate-400 hover:text-blue-600 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/>
                </svg>
              </a>
              <a href="https://github.com/mrezk84" target="_blank" class="text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Image - Modern 2025 Style -->
          <div class="flex justify-center order-1 lg:order-2" data-aos="fade-left" data-aos-duration="1000">
            <div class="relative">
              <!-- Gradient glow background -->
              <div class="absolute -inset-6 bg-gradient-to-r from-amber-400 via-yellow-400 to-amber-500 rounded-[3rem] blur-3xl opacity-40 animate-pulse"></div>

              <!-- Main image container -->
              <div class="relative glass-modern rounded-[2.5rem] p-3 shadow-2xl">
                <img
                  src={`${basePath}/perfil.jpg`}
                  alt="Marcos Rezk - Full Stack Developer"
                  class="relative w-64 h-64 sm:w-80 sm:h-80 rounded-[2rem] object-cover"
                />

                <!-- Floating tech badges -->
                <div class="absolute -top-3 -left-3 px-3 py-1.5 bg-gradient-to-r from-cyan-500 to-blue-500 rounded-xl shadow-lg text-white text-xs font-bold">
                  React
                </div>
                <div class="absolute -top-3 -right-3 px-3 py-1.5 bg-gradient-to-r from-purple-500 to-violet-500 rounded-xl shadow-lg text-white text-xs font-bold">
                  .NET
                </div>
                <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 px-4 py-2 bg-gradient-to-r from-green-400 to-emerald-500 rounded-xl shadow-lg text-white text-sm font-bold flex items-center gap-2">
                  <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
                  </span>
                  Open to Work
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll Indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
        <span class="text-sm text-slate-500 dark:text-slate-400">Conoce más</span>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-amber-500">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </div>
    </section>

    <!-- Stats Section - Social Proof -->
    <section class="py-16 bg-white dark:bg-slate-900 border-y border-slate-200 dark:border-slate-800" data-aos="fade-up">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          {stats.map((stat, index) => (
            <div class="text-center group" data-aos="fade-up" data-aos-delay={index * 100}>
              <div class="text-4xl sm:text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-amber-500 to-yellow-600 dark:from-amber-400 dark:to-yellow-400 mb-2">
                {stat.value}
              </div>
              <p class="text-slate-600 dark:text-slate-400 text-sm sm:text-base">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Value Proposition - Modern Cards -->
    <section class="py-24 bg-slate-50 dark:bg-slate-950" data-aos="fade-up">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-2 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full text-sm font-medium mb-4">
            Propuesta de valor
          </span>
          <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100">
            ¿Por qué <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-500 to-yellow-500">contratarme</span>?
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            {
              icon: "🎯",
              title: "Enfoque en resultados",
              description: "Optimización de consultas SQL con 40% mejora en rendimiento. Soluciones que impactan directamente en la operación.",
              gradient: "from-orange-400 to-red-500"
            },
            {
              icon: "🔄",
              title: "Aprendizaje continuo",
              description: "Constante actualización tecnológica. Egresado reciente con conocimientos frescos y experiencia práctica.",
              gradient: "from-blue-400 to-cyan-500"
            },
            {
              icon: "🤝",
              title: "Trabajo en equipo",
              description: "Experiencia en metodologías ágiles (Scrum, Kanban). Colaboración efectiva con equipos multidisciplinarios.",
              gradient: "from-purple-400 to-violet-500"
            },
            {
              icon: "🏆",
              title: "Proyectos críticos",
              description: "Desarrollo de sistemas para el Ministerio del Interior y SEMM. Código que salva vidas.",
              gradient: "from-amber-400 to-yellow-500"
            }
          ].map((value, index) => (
            <div
              class="group relative bg-white dark:bg-slate-900 rounded-3xl p-6 shadow-lg border border-slate-100 dark:border-slate-800 hover-lift overflow-hidden"
              data-aos="fade-up"
              data-aos-delay={index * 100}
            >
              <!-- Background gradient on hover -->
              <div class="absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-500 from-slate-50 to-transparent dark:from-slate-800/50"></div>

              <!-- Icon container -->
              <div class={`relative w-14 h-14 rounded-2xl bg-gradient-to-br ${value.gradient} flex items-center justify-center text-2xl shadow-lg mb-5 group-hover:scale-110 transition-transform duration-300`}>
                {value.icon}
              </div>

              <h3 class="relative font-bold text-lg mb-2 text-slate-900 dark:text-slate-100">{value.title}</h3>
              <p class="relative text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Services Section - Bento Grid Layout (2025 trend) -->
    <section class="py-24 bg-white dark:bg-slate-900" data-aos="fade-up">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-2 bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-full text-sm font-medium mb-4">
            Servicios
          </span>
          <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100">
            Lo que puedo hacer por <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-500 to-yellow-500">ti</span>
          </h2>
        </div>

        <!-- Bento Grid -->
        <div class="bento-grid">
          <!-- Frontend - Large card -->
          <div class="bento-card-3 glass-card rounded-3xl p-8 hover-lift scroll-fade-in" data-aos="fade-up">
            <div class="h-full flex flex-col">
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-3xl shadow-lg mb-6">
                ⚛️
              </div>
              <h3 class="font-bold text-2xl mb-3 text-slate-900 dark:text-slate-100">Desarrollo Frontend</h3>
              <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed flex-1">
                Aplicaciones web modernas con React, JavaScript y CSS. Interfaces responsivas y experiencia de usuario optimizada.
              </p>
              <div class="flex flex-wrap gap-2">
                {["React", "JavaScript", "HTML/CSS", "XAML"].map((tech) => (
                  <span class="px-3 py-1.5 bg-white/50 dark:bg-slate-800/50 rounded-xl text-sm text-cyan-700 dark:text-cyan-400 font-medium border border-cyan-200/50 dark:border-cyan-800/30">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Backend - Standard card -->
          <div class="bento-card-2 glass-card rounded-3xl p-8 hover-lift scroll-fade-in" data-aos="fade-up" data-aos-delay="100">
            <div class="h-full flex flex-col">
              <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-400 to-violet-500 flex items-center justify-center text-2xl shadow-lg mb-5">
                🔷
              </div>
              <h3 class="font-bold text-xl mb-2 text-slate-900 dark:text-slate-100">Desarrollo Backend</h3>
              <p class="text-slate-600 dark:text-slate-400 mb-4 text-sm leading-relaxed flex-1">
                APIs robustas y escalables con C# .NET, Node.js y Java.
              </p>
              <div class="flex flex-wrap gap-2">
                {["C# .NET", "Node.js", "Java"].map((tech) => (
                  <span class="px-2.5 py-1 bg-white/50 dark:bg-slate-800/50 rounded-lg text-xs text-purple-700 dark:text-purple-400 font-medium">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Database - Standard card -->
          <div class="bento-card-2 glass-card rounded-3xl p-8 hover-lift scroll-fade-in" data-aos="fade-up" data-aos-delay="200">
            <div class="h-full flex flex-col">
              <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-red-400 to-rose-500 flex items-center justify-center text-2xl shadow-lg mb-5">
                🗄️
              </div>
              <h3 class="font-bold text-xl mb-2 text-slate-900 dark:text-slate-100">Bases de Datos</h3>
              <p class="text-slate-600 dark:text-slate-400 mb-4 text-sm leading-relaxed flex-1">
                Diseño y optimización con 40% mejora en rendimiento.
              </p>
              <div class="flex flex-wrap gap-2">
                {["SQL Server", "PostgreSQL", "MongoDB"].map((tech) => (
                  <span class="px-2.5 py-1 bg-white/50 dark:bg-slate-800/50 rounded-lg text-xs text-red-700 dark:text-red-400 font-medium">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Integrations - Tall card -->
          <div class="bento-card-4 glass-card rounded-3xl p-8 hover-lift scroll-fade-in" data-aos="fade-up" data-aos-delay="300">
            <div class="h-full flex flex-col">
              <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center text-2xl shadow-lg mb-5">
                🔗
              </div>
              <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-slate-100">Integraciones</h3>
              <p class="text-slate-600 dark:text-slate-400 mb-4 text-sm leading-relaxed">
                Integración de servicios web, APIs REST/SOAP, LDAP, ArcGIS y sistemas de telefonía como Asterisk.
              </p>
              <div class="flex flex-wrap gap-2 mt-auto">
                {["REST APIs", "WCF", "ArcGIS"].map((tech) => (
                  <span class="px-2.5 py-1 bg-white/50 dark:bg-slate-800/50 rounded-lg text-xs text-emerald-700 dark:text-emerald-400 font-medium">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- CTA in Services -->
        <div class="mt-16 text-center scroll-fade-in">
          <a
            href="#contacto"
            class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-amber-500 to-yellow-500 text-slate-900 rounded-2xl font-bold shadow-lg shadow-amber-500/30 hover:shadow-xl hover:shadow-amber-500/40 hover:-translate-y-1 transition-all duration-300 magnetic-hover"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
