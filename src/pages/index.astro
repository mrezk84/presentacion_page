---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SkipLink from "../components/SkipLink.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import AOSInit from "../components/AOSInit";
import ProjectsSection from "../components/ProjectsSection.astro";
import GitHubRepos from "../components/GitHubRepos.astro";
import TestimonialsSection from "../components/TestimonialsSection.astro";
import CertificationsSection from "../components/CertificationsSection.astro";
import LanguagesSection from "../components/LanguagesSection.astro";
import "../styles/global.css";

// Get base path for GitHub Pages
const isVercel = process.env.VERCEL === '1';
const basePath = isVercel ? '' : '/presentacion_page';

const name = "Marcos Rezk";
const role = "Full Stack Developer";

const stats = [
  { value: "3+", label: "Años de experiencia" },
  { value: "10+", label: "Proyectos entregados" },
  { value: "5", label: "Tecnologías principales" },
  { value: "100%", label: "Compromiso con calidad" }
];

const skills = [
  { name: "React", level: 90, icon: "⚛️", color: "from-cyan-400 to-blue-500" },
  { name: "C# .NET", level: 85, icon: "🔷", color: "from-purple-400 to-purple-600" },
  { name: "SQL Server", level: 80, icon: "🗄️", color: "from-red-400 to-red-600" },
  { name: "JavaScript", level: 88, icon: "📜", color: "from-yellow-400 to-yellow-600" },
  { name: "Node.js", level: 75, icon: "🟢", color: "from-green-400 to-green-600" },
  { name: "ArcGIS", level: 70, icon: "🗺️", color: "from-emerald-400 to-teal-600" }
];
---

<Layout
  title="Marcos Rezk | Full Stack Developer - React, C#, SQL Server"
  description="Full Stack Developer con experiencia construyendo aplicaciones web escalables con React, C# .NET y SQL Server. Egresado de ORT Uruguay."
>
  <SkipLink />
  <AOSInit client:load />

  <Header />
  <ScrollToTop />

  <main id="main-content" class="min-h-screen" role="main">
    <!-- Hero Section - Rediseñado -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
      <!-- Animated Background -->
      <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-amber-50/30 to-slate-100 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950">
        <div class="absolute inset-0 opacity-30">
          <div class="absolute top-20 left-10 w-72 h-72 bg-amber-400/20 rounded-full blur-3xl animate-pulse"></div>
          <div class="absolute bottom-20 right-10 w-96 h-96 bg-blue-400/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-amber-500/10 rounded-full blur-3xl"></div>
        </div>
      </div>

      <div class="relative z-10 max-w-6xl mx-auto px-6 py-24">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Text Content -->
          <div class="text-center lg:text-left order-2 lg:order-1" data-aos="fade-right" data-aos-duration="1000">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-amber-100 dark:bg-amber-900/30 rounded-full mb-6">
              <span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></span>
              <span class="text-sm font-medium text-amber-700 dark:text-amber-300">Disponible para oportunidades</span>
            </div>

            <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight mb-6">
              <span class="block text-slate-900 dark:text-slate-100 font-serif">Hola, soy</span>
              <span class="block mt-2">
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-500 via-yellow-500 to-amber-600 dark:from-amber-400 dark:via-yellow-400 dark:to-amber-500 animate-gradient">
                  {name}
                </span>
              </span>
            </h1>

            <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-3 mb-8">
              <span class="text-2xl sm:text-3xl text-slate-700 dark:text-slate-300 font-serif">{role}</span>
              <a href={`${basePath}/titulo.png`} target="_blank" class="group flex items-center gap-2">
                <div class="relative">
                  <div class="absolute -inset-1 bg-gradient-to-r from-red-500 to-red-700 rounded-full blur opacity-0 group-hover:opacity-40 transition duration-300"></div>
                  <img src={`${basePath}/ort_logo.png`} alt="ORT Uruguay" class="relative w-8 h-8 rounded-full object-cover shadow-lg group-hover:scale-110 transition-transform duration-300" />
                </div>
                <span class="text-sm text-red-600 dark:text-red-400 font-medium">ORT Uruguay</span>
              </a>
            </div>

            <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-10 max-w-xl mx-auto lg:mx-0">
              Especializado en desarrollar aplicaciones web escalables con <strong class="text-slate-900 dark:text-slate-100">React</strong>, <strong class="text-slate-900 dark:text-slate-100">C# .NET</strong> y <strong class="text-slate-900 dark:text-slate-100">SQL Server</strong>. He construido soluciones críticas para el Ministerio del Interior y SEMM.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
              <a
                href={`${basePath}/CV_Marcos_Rezk_ES.pdf`}
                download
                class="group relative inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r from-amber-500 to-yellow-500 text-slate-900 rounded-2xl font-bold shadow-lg shadow-amber-500/30 hover:shadow-xl hover:shadow-amber-500/40 hover:-translate-y-1 transition-all duration-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M12 12.75l-3-3m0 0 3-3m-3 3h7.5" />
                </svg>
                <span>Descargar CV</span>
              </a>
              <a
                href="#contacto"
                class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 rounded-2xl font-semibold border-2 border-slate-200 dark:border-slate-700 hover:border-amber-500 dark:hover:border-amber-500 hover:text-amber-600 dark:hover:text-amber-400 transition-all duration-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                <span>Contactar</span>
              </a>
            </div>
          </div>

          <!-- Image -->
          <div class="flex justify-center order-1 lg:order-2" data-aos="fade-left" data-aos-duration="1000">
            <div class="relative">
              <div class="absolute -inset-4 bg-gradient-to-r from-amber-400 to-yellow-500 rounded-[2.5rem] blur-2xl opacity-30 animate-pulse"></div>
              <div class="relative">
                <div class="absolute inset-0 bg-gradient-to-br from-amber-400/20 to-yellow-500/20 rounded-[2rem]"></div>
                <img
                  src={`${basePath}/perfil.jpg`}
                  alt="Marcos Rezk"
                  class="relative w-64 h-64 sm:w-80 sm:h-80 rounded-[2rem] object-cover shadow-2xl border-4 border-white dark:border-slate-800"
                />
                <!-- Floating Badge -->
                <div class="absolute -bottom-4 -right-4 bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-4 border border-slate-100 dark:border-slate-700">
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 bg-gradient-to-br from-green-400 to-emerald-500 rounded-xl flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-white">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
                      </svg>
                    </div>
                    <div>
                      <p class="text-xs text-slate-500 dark:text-slate-400">Estado</p>
                      <p class="text-sm font-semibold text-slate-900 dark:text-slate-100">Disponible</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Scroll Indicator -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
          <span class="text-sm text-slate-500 dark:text-slate-400">Descubre más</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-amber-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-16 bg-white dark:bg-slate-900 border-y border-slate-200 dark:border-slate-800" data-aos="fade-up">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          {stats.map((stat, index) => (
            <div class="text-center group" data-aos="fade-up" data-aos-delay={index * 100}>
              <div class="text-4xl sm:text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-amber-500 to-yellow-600 dark:from-amber-400 dark:to-yellow-400 mb-2">
                {stat.value}
              </div>
              <p class="text-slate-600 dark:text-slate-400 text-sm sm:text-base">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class="py-24 bg-slate-50 dark:bg-slate-950" data-aos="fade-up">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-2 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full text-sm font-medium mb-4">
            Sobre mí
          </span>
          <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100 font-serif">
            Apasionado por crear <span class="text-amber-500">soluciones digitales</span>
          </h2>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-6">
            <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
              Soy un desarrollador Full Stack egresado de la <strong class="text-slate-900 dark:text-slate-100">Universidad ORT Uruguay</strong> con más de 3 años de experiencia en el desarrollo de aplicaciones web escalables.
            </p>
            <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
              Mi trayectoria profesional incluye trabajar en proyectos críticos para instituciones como el <strong class="text-slate-900 dark:text-slate-100">Ministerio del Interior</strong> (sistemas 911 y denuncias ciudadanas) y <strong class="text-slate-900 dark:text-slate-100">SEMM</strong>, donde he desarrollado soluciones tecnológicas que impactan directamente en la vida de las personas.
            </p>
            <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
              Me caracterizo por mi <strong class="text-slate-900 dark:text-slate-100">compromiso con la calidad</strong>, capacidad de aprendizaje continuo y enfoque en las buenas prácticas de desarrollo. Siempre busco optimizar procesos y mejorar la eficiencia de las aplicaciones.
            </p>
          </div>

          <div class="space-y-4">
            {skills.slice(0, 4).map((skill, index) => (
              <div class="bg-white dark:bg-slate-900 rounded-2xl p-5 shadow-lg border border-slate-100 dark:border-slate-800 hover:shadow-xl transition-shadow" data-aos="fade-left" data-aos-delay={index * 100}>
                <div class="flex items-center justify-between mb-3">
                  <div class="flex items-center gap-3">
                    <span class="text-2xl">{skill.icon}</span>
                    <span class="font-semibold text-slate-900 dark:text-slate-100">{skill.name}</span>
                  </div>
                  <span class="text-sm font-medium text-amber-600 dark:text-amber-400">{skill.level}%</span>
                </div>
                <div class="h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                  <div class={`h-full bg-gradient-to-r ${skill.color} rounded-full transition-all duration-1000`} style="width: 0%" data-width={skill.level}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Experience Section - Timeline -->
    <section id="experiencia" class="py-24 bg-white dark:bg-slate-900 scroll-mt-24" data-aos="fade-up">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-2 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full text-sm font-medium mb-4">
            Trayectoria profesional
          </span>
          <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100 font-serif">
            Experiencia Laboral
          </h2>
        </div>

        <div class="relative">
          <!-- Timeline Line -->
          <div class="absolute left-0 sm:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-amber-500 to-transparent sm:-translate-x-1/2"></div>

          <!-- SONDA -->
          <div class="relative mb-12" data-aos="fade-up">
            <div class="flex flex-col sm:flex-row gap-6 items-start">
              <div class="sm:w-1/2 sm:text-right sm:pr-12">
                <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-6 shadow-lg border border-slate-100 dark:border-slate-700 hover:shadow-xl transition-shadow sm:ml-auto sm:mr-0 max-w-md">
                  <span class="inline-block px-3 py-1 bg-amber-500 text-white text-xs font-bold rounded-full mb-3">Actualidad</span>
                  <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 font-serif mb-2">Desarrollador Full Stack</h3>
                  <p class="text-amber-600 dark:text-amber-400 font-medium mb-4">SONDA Uruguay · 2022 – Presente</p>
                  <ul class="space-y-2 text-slate-600 dark:text-slate-400 text-sm">
                    <li class="flex items-start gap-2 sm:justify-end">
                      <span class="text-amber-500 mt-1">•</span>
                      <span>Desarrollo en React y C# .NET para sistemas críticos del Ministerio del Interior</span>
                    </li>
                    <li class="flex items-start gap-2 sm:justify-end">
                      <span class="text-amber-500 mt-1">•</span>
                      <span>Implementación de módulos de grabación y exportación de reportes PDF</span>
                    </li>
                    <li class="flex items-start gap-2 sm:justify-end">
                      <span class="text-amber-500 mt-1">•</span>
                      <span>Integración de APIs REST, autenticación LDAP y mapas ArcGIS</span>
                    </li>
                    <li class="flex items-start gap-2 sm:justify-end">
                      <span class="text-amber-500 mt-1">•</span>
                      <span>Optimización de SQL Server (40% mejora en rendimiento)</span>
                    </li>
                  </ul>
                </div>
              </div>
              <div class="absolute left-0 sm:left-1/2 w-4 h-4 bg-amber-500 rounded-full border-4 border-white dark:border-slate-900 sm:-translate-x-1/2 -translate-y-2 top-8"></div>
              <div class="sm:w-1/2 sm:pl-12"></div>
            </div>
          </div>

          <!-- ANCAP -->
          <div class="relative mb-12" data-aos="fade-up" data-aos-delay="100">
            <div class="flex flex-col sm:flex-row gap-6 items-start">
              <div class="sm:w-1/2 sm:pr-12 order-2 sm:order-1"></div>
              <div class="absolute left-0 sm:left-1/2 w-4 h-4 bg-slate-400 rounded-full border-4 border-white dark:border-slate-900 sm:-translate-x-1/2 -translate-y-2 top-8"></div>
              <div class="sm:w-1/2 sm:pl-12 order-1 sm:order-2">
                <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-6 shadow-lg border border-slate-100 dark:border-slate-700 hover:shadow-xl transition-shadow max-w-md">
                  <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 font-serif mb-2">Supervisor de Mesa de Ayuda</h3>
                  <p class="text-amber-600 dark:text-amber-400 font-medium mb-4">ANCAP · 2018 – 2022</p>
                  <ul class="space-y-2 text-slate-600 dark:text-slate-400 text-sm">
                    <li class="flex items-start gap-2">
                      <span class="text-amber-500 mt-1">•</span>
                      <span>Gestión de equipo de soporte técnico (13 personas)</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-amber-500 mt-1">•</span>
                      <span>Coordinación con áreas técnicas para cierre de tickets críticos</span>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- SONDA Manager -->
          <div class="relative" data-aos="fade-up" data-aos-delay="200">
            <div class="flex flex-col sm:flex-row gap-6 items-start">
              <div class="sm:w-1/2 sm:text-right sm:pr-12">
                <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-6 shadow-lg border border-slate-100 dark:border-slate-700 hover:shadow-xl transition-shadow sm:ml-auto sm:mr-0 max-w-md">
                  <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 font-serif mb-2">Manager</h3>
                  <p class="text-amber-600 dark:text-amber-400 font-medium mb-4">SONDA Uruguay · 2009 – 2018</p>
                  <ul class="space-y-2 text-slate-600 dark:text-slate-400 text-sm">
                    <li class="flex items-start gap-2 sm:justify-end">
                      <span class="text-amber-500 mt-1">•</span>
                      <span>Coordinación de proyectos técnicos a nivel nacional</span>
                    </li>
                    <li class="flex items-start gap-2 sm:justify-end">
                      <span class="text-amber-500 mt-1">•</span>
                      <span>Supervisión de implementación de soluciones empresariales</span>
                    </li>
                  </ul>
                </div>
              </div>
              <div class="absolute left-0 sm:left-1/2 w-4 h-4 bg-slate-400 rounded-full border-4 border-white dark:border-slate-900 sm:-translate-x-1/2 -translate-y-2 top-8"></div>
              <div class="sm:w-1/2 sm:pl-12"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <ProjectsSection />

    <!-- GitHub Repos Section -->
    <GitHubRepos />

    <!-- Tech Stack - Rediseñado -->
    <section id="tecnologias" class="py-24 bg-slate-50 dark:bg-slate-950 scroll-mt-24" data-aos="fade-up">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-2 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full text-sm font-medium mb-4">
            Stack tecnológico
          </span>
          <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100 font-serif">
            Tecnologías que domino
          </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {[
            { name: "React", icon: "⚛️", color: "hover:from-cyan-400 hover:to-blue-500" },
            { name: "C# .NET", icon: "🔷", color: "hover:from-purple-400 hover:to-purple-600" },
            { name: "SQL Server", icon: "🗄️", color: "hover:from-red-400 hover:to-red-600" },
            { name: "PostgreSQL", icon: "🐘", color: "hover:from-blue-400 hover:to-indigo-600" },
            { name: "JavaScript", icon: "📜", color: "hover:from-yellow-400 hover:to-yellow-600" },
            { name: "Java", icon: "☕", color: "hover:from-orange-500 hover:to-red-600" },
            { name: "Node.js", icon: "🟢", color: "hover:from-green-400 hover:to-green-600" },
            { name: "Spring Boot", icon: "🍃", color: "hover:from-green-500 hover:to-emerald-600" },
            { name: "HTML/CSS", icon: "🎨", color: "hover:from-orange-400 hover:to-orange-600" },
            { name: "ArcGIS", icon: "🗺️", color: "hover:from-emerald-400 hover:to-teal-600" },
            { name: "MongoDB", icon: "🍃", color: "hover:from-green-500 hover:to-green-700" },
            { name: "WCF", icon: "🔌", color: "hover:from-blue-400 hover:to-blue-600" },
            { name: "WPF", icon: "🖥️", color: "hover:from-slate-400 hover:to-slate-600" },
            { name: "REST APIs", icon: "🔗", color: "hover:from-indigo-400 hover:to-indigo-600" },
            { name: "LDAP", icon: "🔐", color: "hover:from-amber-400 hover:to-amber-600" },
            { name: "Go", icon: "🐹", color: "hover:from-cyan-400 hover:to-blue-600" },
            { name: "Git", icon: "📦", color: "hover:from-orange-400 hover:to-red-500" }
          ].map((tech, index) => (
            <div
              class="group bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-lg border border-slate-100 dark:border-slate-800 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 text-center"
              data-aos="fade-up"
              data-aos-delay={index * 50}
            >
              <div class={`text-4xl mb-3 group-hover:scale-110 transition-transform duration-300`}>
                {tech.icon}
              </div>
              <p class="font-semibold text-slate-900 dark:text-slate-100">{tech.name}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Agile Methodologies Section -->
    <section class="py-24 bg-white dark:bg-slate-900" data-aos="fade-up">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-2 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-full text-sm font-medium mb-4">
            Metodología
          </span>
          <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100 font-serif">
            Metodologías Ágiles
          </h2>
          <p class="text-lg text-slate-600 dark:text-slate-400 mt-4 max-w-2xl mx-auto">
            Experiencia trabajando en equipos ágiles con enfoque en colaboración y entrega continua.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- Scrum -->
